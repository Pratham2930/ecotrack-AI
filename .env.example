# ─────────────────────────────────────────────────────────────────────────────
# EcoTrack AI — environment variables
#
# Copy this file to `.env` and fill in your own values.
# Without these, the app runs in DEMO MODE (localStorage-backed auth + data),
# so you can develop and evaluate it without any cloud credentials.
# ─────────────────────────────────────────────────────────────────────────────

# Firebase web app config (Project settings → General → Your apps → SDK setup)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ─────────────────────────────────────────────────────────────────────────────
# Optional — AI Climate Coach (serverless function at /api/coach)
# Set these in your Vercel project (NOT prefixed with VITE_, server-side only).
# If omitted, the coach uses the built-in rule-based engine.
# ─────────────────────────────────────────────────────────────────────────────
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
