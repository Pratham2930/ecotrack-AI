rules_version = '2';

// EcoTrack AI — Firestore security rules.
//
// Each user document lives at /users/{uid} and is private to its owner.
// Reference datasets (countries, marketplace, challenges) are bundled in the
// client, so no public collections are exposed here. Lock everything else down.
service cloud.firestore {
  match /databases/{database}/documents {

    // A user can only read/write their own document.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      // Any nested sub-collections (entries, goals, etc.) inherit ownership.
      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
